{
  "name": "@photobooth/source",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "api:restore": "dotnet restore apps/api/Photobooth.Api.csproj",
    "api:build": "dotnet build apps/api/Photobooth.Api.csproj -c Release",
    "api:run": "dotnet run --project apps/api/Photobooth.Api.csproj",
    "api:watch": "dotnet watch run --project apps/api/Photobooth.Api.csproj",
    "api:migrate": "DOTNET_ROOT=/usr/share/dotnet ~/.dotnet/tools/dotnet-ef migrations add $(date +%s) --project apps/api/Photobooth.Api.csproj --startup-project apps/api/Photobooth.Api.csproj",
    "api:db-update": "DOTNET_ROOT=/usr/share/dotnet ~/.dotnet/tools/dotnet-ef database update --project apps/api/Photobooth.Api.csproj --startup-project apps/api/Photobooth.Api.csproj",
    "client:build": "npx nx run client:build",
    "client:run": "npx nx run client:run",
    "client:register": "npx nx run client:register",
    "client:upload-file": "npx nx run client:upload-file",
    "web:dev": "npx nx run web:dev",
    "web:build": "npx nx run web:build",
    "web:preview": "npx nx run web:preview"
  },
  "devDependencies": {
    "@nx/js": "^22.6.1",
    "@nx/react": "^22.6.1",
    "@nx/vite": "^22.6.1",
    "@nx/workspace": "^22.6.1",
    "nx": "22.6.1"
  }
}
