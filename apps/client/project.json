{
  "name": "client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "apps/client",
  "sourceRoot": "apps/client",
  "targets": {
    "build": {
      "command": "dotnet build apps/client/Photobooth.Client.csproj -c Release"
    },
    "dev": {
      "command": "bash ./scripts/client-dev-run.sh --watch"
    },
    "run": {
      "command": "bash ./scripts/client-dev-run.sh"
    },
    "register": {
      "command": "bash ./scripts/client-dev-register.sh"
    },
    "upload-file": {
      "command": "bash ./scripts/client-dev-upload.sh"
    }
  }
}
