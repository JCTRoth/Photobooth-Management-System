{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web/src",
  "targets": {
    "dev": {
      "command": "npx vite",
      "options": {
        "cwd": "apps/web"
      }
    },
    "build": {
      "command": "npx vite build",
      "options": {
        "cwd": "apps/web"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "preview": {
      "command": "npx vite preview",
      "options": {
        "cwd": "apps/web"
      }
    }
  }
}
