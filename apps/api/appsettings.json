{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Photobooth.Api.Jobs": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=photobooth;Username=photobooth;Password=changeme"
  },
  "Sftp": {
    "Host": "sftp.example.com",
    "Port": 22,
    "Username": "sftp_user",
    "Password": "changeme",
    "BasePath": "/weddings",
    "PublicBaseUrl": "https://photos.example.com"
  },
  "Upload": {
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [".jpg", ".jpeg", ".png"],
    "AllowedContentTypes": ["image/jpeg", "image/png"]
  },
  "Cors": {
    "Origins": ["http://localhost:5173"]
  },
  "IpRateLimit": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/upload/*",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "POST:/api/auth/*/request",
        "Period": "1h",
        "Limit": 50
      },
      {
        "Endpoint": "POST:/api/auth/*",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 20
      }
    ]
  },
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "Username": "smtp_user",
    "Password": "changeme",
    "FromAddress": "noreply@example.com",
    "FromName": "Photobooth",
    "UseStartTls": true
  },
  "Jwt": {
    "Secret": "CHANGE_ME_use_a_long_random_secret_min_32_chars",
    "Issuer": "photobooth-api",
    "Audience": "photobooth-app",
    "AccessTokenMinutes": 15,
    "RefreshTokenHours": 72
  },
  "AppBaseUrl": "https://photobooth.example.com",
  "AllowedHosts": "*"
}
